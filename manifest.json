{
  "manifest_version": 3,
  "name": "AuraAudio EQ & Dynamics",
  "version": "1.0",
  "description": "4-Band Parametric EQ, Compressor, and Limiter for Web Audio.",
  "homepage_url": "https://github.com/Shohei-Tsuchiya/chromeeqanddynamics",
  "permissions": [
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon-16.png",
      "32": "icon-32.png",
      "48": "icon-48.png",
      "128": "icon.png"
    }
  },
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": ["settings.js", "content.js"],
      "run_at": "document_end",
      "all_frames": true
    }
  ]
}
